{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "phases": {
        "setup": {
          "nixPkgs": ["python311", "gcc"]
        },
        "build": {
          "cmds": ["pip install -r requirements.txt"]  // Agregá esto para que instale telebot y deps
        }
      }
    }
  },
  "deploy": {
    "startCommand": "python bot.py",
    "restartPolicyType": "ALWAYS",  // Cambié a ALWAYS para retry infinito
    "restartPolicyMaxRetries": 10,
    "sleepApplication": false  // No duerme el container
  }
}
