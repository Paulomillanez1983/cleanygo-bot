{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "providers": ["python"],
      "phases": {
        "setup": {
          "nixPkgs": ["python311", "gcc"]
        },
        "build": {
          "cmds": ["pip install --no-cache-dir -r requirements.txt"]
        }
      }
    }
  },
  "deploy": {
    "startCommand": "python bot.py",  // o el nombre exacto de tu archivo principal (donde está if __name__ == "__main__")
    "restartPolicyType": "ALWAYS",
    "restartPolicyMaxRetries": -1,  // infinito
    "sleepApplication": false
  }
}
