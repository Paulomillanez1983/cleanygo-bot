{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "providers": ["python"],
      "phases": {
        "setup": {
          "nixPkgs": ["python311", "gcc"]
        },
        "build": {
          "cmds": ["pip install --no-cache-dir -r requirements.txt"]
        }
      }
    }
  },
  "deploy": {
    "startCommand": "python bot.py",
    "restartPolicyType": "ALWAYS",
    "restartPolicyMaxRetries": 10,
    "sleepApplication": false,
    "healthcheckPath": "/health",          // ← Agregado: endpoint simple para chequear si vive
    "healthcheckTimeout": 30000,           // 30 segundos de timeout
    "healthcheckInterval": 10000           // chequea cada 10 seg
  }
}
